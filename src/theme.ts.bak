};

export const lightTheme: Theme = {
  name: 'light',
  colors: {
    primary: '#6750a4',
    primaryDark: '#4e3d8c',
    secondary: '#6d5c7a',
    background: '#fdfbf7',
    surface: '#ffffff',
    surfaceVariant: '#f2edeb',
    textPrimary: '#1c1b1f',
    textSecondary: '#58545e',
    textMuted: '#736e77',
    border: '#d0cdc7',
    accent: '#03dac6',
