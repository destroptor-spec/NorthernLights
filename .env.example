# Server Port
PORT=3001

# Allowed origins for CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL Database
# Uncomment and edit if your setup differs from defaults
DB_USER=musicuser
DB_PASSWORD=musicpass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=musicdb

# Docker/Podman Container Management
# Used for UI-based database control (start/stop/create)
DB_CONTAINER_NAME=music-postgres
DB_DATA_DIR=./postgres-data

# MBDB Work Directory (where MusicBrainz dump is downloaded/extracted)
MBDB_WORK_DIR=./mbdb-data

# Server Base URL (used for OAuth2 callback redirects for MusicBrainz and Last.fm)
# Set this to your public-facing URL if running behind a reverse proxy
# SERVER_URL=http://localhost:3001

# LLM Configuration (optional)
# Can also be configured via Settings > Providers in the app.
# These env vars serve as fallback if DB settings are not set.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL_NAME=gpt-4

# Custom Chromecast Receiver (optional)
# Register a Custom Web Receiver at https://cast.google.com/publish
# Host public/receiver.html on a publicly accessible HTTPS URL.
# Set that URL in the Cast Developer Console and paste the App ID here.
# When set, Chromecast will use HLS streaming instead of raw file URLs.
# CAST_RECEIVER_APP_ID=
# The public origin hosting the receiver HTML (for CORS on HLS segments)
# CAST_RECEIVER_ORIGIN=https://your-domain.com
