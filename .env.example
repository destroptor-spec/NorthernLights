# Server Port
PORT=3001

# Production Basic Authentication
# Change these values before deploying!
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Allowed origins for CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:3000

# LLM Configuration (for Hub playlist generation)
# Leave LLM_API_KEY blank to disable AI playlists.
# Compatible with any OpenAI-API-compatible provider (OpenAI, Ollama, LM Studio, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o
